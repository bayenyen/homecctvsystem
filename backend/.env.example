# Required
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE
JWT_SECRET=replace-with-a-long-random-secret

# Server
PORT=5000
NODE_ENV=development
JWT_EXPIRE=7d

# Comma-separated frontend origins allowed by CORS and Socket.IO.
# Example: http://localhost:5173,https://your-app.vercel.app
CLIENT_URLS=http://localhost:5173

# Enable only on a trusted backend running inside the same LAN as the cameras.
ENABLE_LAN_DISCOVERY=true

# FFmpeg
FFMPEG_PATH=ffmpeg

# Recordings
RECORDINGS_PATH=./recordings
MAX_STORAGE_GB=50
AUTO_DELETE_ON_FULL=true

# Admin seed account
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me
SEED_ADMIN_EMAIL=admin@example.com

# Email notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
